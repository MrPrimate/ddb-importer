{
  "name": "ddb-importer",
  "version": "6.6.54",
  "author": "MrPrimate",
  "description": "Foundry VTT module for integrating D&D Beyond content.",
  "private": true,
  "scripts": {
    "lint": "npx eslint src/",
    "lint-fix": "npx eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run clear; npm run link; webpack",
    "dev": "npm run link && node esbuild.config.mjs --watch",
    "dev:build": "npm run clear && npm run link && node esbuild.config.mjs",
    "clear": "rm -rf dist/*",
    "createSymlinks": "node ./tools/create-symlinks.mjs",
    "link": "cd src/parser/enrichers && node _linkBuilder.js",
    "dev-link": "node ./tools/foundry-dev-link.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^46.5.0",
    "node-fetch": "^3.2.10",
    "prettier": "3.1.0",
    "prettier-eslint": "^16.3.0",
    "prompts": "^2.4.2",
    "terser": "^5.10.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.76.0",
    "webpack-cli": "^4.7.2"
  }
}
