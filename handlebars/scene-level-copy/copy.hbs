<section class="ddb-level-copy">
  <header class="ddb-level-copy-header">
    <h3>Copy from "{{sourceName}}"</h3>
  </header>

  <div class="ddb-level-copy-config">
    <div class="ddb-level-copy-row">
      <label>Source level
        <select class="ddb-level-copy-source-level">
          {{#each sourceLevels}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </label>
    </div>

    <div class="ddb-level-copy-row">
      <label>Target scene
        <select class="ddb-level-copy-target-scene">
          {{#each targetScenes}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </label>
      <label>Target level
        <select class="ddb-level-copy-target-level">
          {{#each targetLevels}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </label>
    </div>

    {{#if sameLevel}}
      <p class="notification warning">Source and target level are the same - pick a different target.</p>
    {{/if}}

    <div class="ddb-level-copy-types">
      <span class="ddb-level-copy-label">Object types</span>
      {{#each typeRows}}
        <label class="ddb-level-copy-type">
          <input type="checkbox" data-action="toggleType" data-type="{{this.id}}" {{#if this.selected}}checked{{/if}} />
          {{this.label}} <span class="hint">({{this.count}})</span>
        </label>
      {{/each}}
    </div>

    <div class="ddb-level-copy-modes">
      <span class="ddb-level-copy-label">Scale / alignment</span>
      <label><input type="radio" name="scaleMode" data-action="setScaleMode" data-mode="none" {{#if modeNone}}checked{{/if}} /> None (verbatim)</label>
      <label><input type="radio" name="scaleMode" data-action="setScaleMode" data-mode="ratio" {{#if modeRatio}}checked{{/if}} /> Grid-size ratio</label>
      <label><input type="radio" name="scaleMode" data-action="setScaleMode" data-mode="hint" {{#if modeHint}}checked{{/if}} /> Align via 3x3 grid</label>
    </div>

    <div class="ddb-level-copy-nudge-row">
      <span class="ddb-level-copy-label">Offset nudge (canvas px)</span>
      <label>X <input type="number" class="ddb-level-copy-nudge" data-axis="x" value="{{offsetNudge.x}}" step="1" /></label>
      <label>Y <input type="number" class="ddb-level-copy-nudge" data-axis="y" value="{{offsetNudge.y}}" step="1" /></label>
    </div>
  </div>

  {{#if modeHint}}
    <div class="ddb-level-copy-hints">
      {{!-- Source surface --}}
      <div class="ddb-level-copy-hint">
        <div class="ddb-level-copy-hint-head">
          <h4>Source 3x3</h4>
          <span class="ddb-grid-picker-zoom-group">
            <button data-action="zoomSourceOut" type="button" class="munch-button icon-only" title="Zoom out"><i class="fas fa-search-minus"></i></button>
            <button data-action="zoomSourceFit" type="button" class="munch-button icon-only" {{#unless sourceZoomedIn}}disabled{{/unless}} title="Fit"><i class="fas fa-expand"></i></button>
            <button data-action="zoomSourceIn" type="button" class="munch-button icon-only" title="Zoom in"><i class="fas fa-search-plus"></i></button>
            <button data-action="redrawSourceHint" type="button" class="munch-button icon-only" {{#unless sourceHasRect}}disabled{{/unless}} title="Redraw"><i class="fas fa-eraser"></i></button>
          </span>
        </div>
        <div class="ddb-grid-picker-canvas">
          <svg viewBox="{{sourceViewBox.x}} {{sourceViewBox.y}} {{sourceViewBox.w}} {{sourceViewBox.h}}" preserveAspectRatio="xMidYMid meet" class="ddb-grid-picker-svg ddb-level-copy-source-svg hint-mode {{#if sourceZoomedIn}}zoomed{{/if}}">
            <image href="{{sourceImageUrl}}" x="0" y="0" width="{{sourceDims.x}}" height="{{sourceDims.y}}" />
            <g class="ddb-grid-picker-hint-group">
              <rect class="ddb-grid-picker-hint-rect"
                x="{{#if sourceHintRect}}{{sourceHintRect.x}}{{else}}0{{/if}}"
                y="{{#if sourceHintRect}}{{sourceHintRect.y}}{{else}}0{{/if}}"
                width="{{#if sourceHintRect}}{{sourceHintRect.w}}{{else}}0{{/if}}"
                height="{{#if sourceHintRect}}{{sourceHintRect.h}}{{else}}0{{/if}}" />
            </g>
            <rect class="ddb-grid-picker-hint-overlay" x="0" y="0" width="{{sourceDims.x}}" height="{{sourceDims.y}}" />
            {{#if sourceHasRect}}
              <g class="ddb-grid-picker-hint-handles">
                {{#each sourceHintHandles}}
                  <rect class="ddb-grid-picker-hint-handle" data-corner="{{this.corner}}" x="{{this.x}}" y="{{this.y}}" width="{{this.size}}" height="{{this.size}}" />
                {{/each}}
              </g>
            {{/if}}
          </svg>
        </div>
        <p class="hint">
          {{#if sourceHasRect}}Cell size: ~{{sourceCellPx}}px. Drag corners to adjust.{{else}}Drag to cover 3x3 cells. Wheel zooms, shift-drag pans.{{/if}}
        </p>
      </div>

      {{!-- Target surface --}}
      <div class="ddb-level-copy-hint">
        <div class="ddb-level-copy-hint-head">
          <h4>Target 3x3</h4>
          <span class="ddb-grid-picker-zoom-group">
            <button data-action="zoomTargetOut" type="button" class="munch-button icon-only" title="Zoom out"><i class="fas fa-search-minus"></i></button>
            <button data-action="zoomTargetFit" type="button" class="munch-button icon-only" {{#unless targetZoomedIn}}disabled{{/unless}} title="Fit"><i class="fas fa-expand"></i></button>
            <button data-action="zoomTargetIn" type="button" class="munch-button icon-only" title="Zoom in"><i class="fas fa-search-plus"></i></button>
            <button data-action="redrawTargetHint" type="button" class="munch-button icon-only" {{#unless targetHasRect}}disabled{{/unless}} title="Redraw"><i class="fas fa-eraser"></i></button>
          </span>
        </div>
        <div class="ddb-grid-picker-canvas">
          <svg viewBox="{{targetViewBox.x}} {{targetViewBox.y}} {{targetViewBox.w}} {{targetViewBox.h}}" preserveAspectRatio="xMidYMid meet" class="ddb-grid-picker-svg ddb-level-copy-target-svg hint-mode {{#if targetZoomedIn}}zoomed{{/if}}">
            <image href="{{targetImageUrl}}" x="0" y="0" width="{{targetDims.x}}" height="{{targetDims.y}}" />
            {{#each preview.lines}}
              <line x1="{{this.x1}}" y1="{{this.y1}}" x2="{{this.x2}}" y2="{{this.y2}}" class="ddb-grid-picker-line" />
            {{/each}}
            {{#each preview.dots}}
              <circle cx="{{this.x}}" cy="{{this.y}}" r="6" class="ddb-level-copy-dot" />
            {{/each}}
            <g class="ddb-grid-picker-hint-group">
              <rect class="ddb-grid-picker-hint-rect"
                x="{{#if targetHintRect}}{{targetHintRect.x}}{{else}}0{{/if}}"
                y="{{#if targetHintRect}}{{targetHintRect.y}}{{else}}0{{/if}}"
                width="{{#if targetHintRect}}{{targetHintRect.w}}{{else}}0{{/if}}"
                height="{{#if targetHintRect}}{{targetHintRect.h}}{{else}}0{{/if}}" />
            </g>
            <rect class="ddb-grid-picker-hint-overlay" x="0" y="0" width="{{targetDims.x}}" height="{{targetDims.y}}" />
            {{#if targetHasRect}}
              <g class="ddb-grid-picker-hint-handles">
                {{#each targetHintHandles}}
                  <rect class="ddb-grid-picker-hint-handle" data-corner="{{this.corner}}" x="{{this.x}}" y="{{this.y}}" width="{{this.size}}" height="{{this.size}}" />
                {{/each}}
              </g>
            {{/if}}
          </svg>
        </div>
        <p class="hint">
          {{#if targetHasRect}}Cell size: ~{{targetCellPx}}px. Projected objects shown in red/blue.{{else}}Drag to cover the same 3x3 cells.{{/if}}
        </p>
      </div>
    </div>
  {{else}}
    {{!-- Non-hint preview over the target image --}}
    <div class="ddb-level-copy-preview">
      <div class="ddb-level-copy-hint-head">
        <h4>Preview on target ({{preview.totalCount}} objects)</h4>
        <span class="ddb-grid-picker-zoom-group">
          <button data-action="zoomTargetOut" type="button" class="munch-button icon-only" title="Zoom out"><i class="fas fa-search-minus"></i></button>
          <button data-action="zoomTargetFit" type="button" class="munch-button icon-only" {{#unless targetZoomedIn}}disabled{{/unless}} title="Fit"><i class="fas fa-expand"></i></button>
          <button data-action="zoomTargetIn" type="button" class="munch-button icon-only" title="Zoom in"><i class="fas fa-search-plus"></i></button>
        </span>
      </div>
      <div class="ddb-grid-picker-canvas">
        <svg viewBox="{{targetViewBox.x}} {{targetViewBox.y}} {{targetViewBox.w}} {{targetViewBox.h}}" preserveAspectRatio="xMidYMid meet" class="ddb-grid-picker-svg ddb-level-copy-target-svg {{#if targetZoomedIn}}zoomed{{/if}}">
          <image href="{{targetImageUrl}}" x="0" y="0" width="{{targetDims.x}}" height="{{targetDims.y}}" />
          {{#each preview.lines}}
            <line x1="{{this.x1}}" y1="{{this.y1}}" x2="{{this.x2}}" y2="{{this.y2}}" class="ddb-grid-picker-line" />
          {{/each}}
          {{#each preview.dots}}
            <circle cx="{{this.x}}" cy="{{this.y}}" r="6" class="ddb-level-copy-dot" />
          {{/each}}
        </svg>
      </div>
      <p class="hint">Projected objects shown over the target level background.</p>
    </div>
  {{/if}}

  <div class="ddb-level-copy-actions">
    <button data-action="copyPlaceables" type="button" class="munch-button" {{#unless canCopy}}disabled{{/unless}}>
      <i class="fas fa-copy"></i> Copy
    </button>
    <button data-action="cancel" type="button" class="munch-button">Cancel</button>
  </div>
</section>
