<section class="ddb-monster-select-content">
  <fieldset>
    <legend>Filter</legend>
    <div class="ddb-monster-filter-selects">
      <div class="form-group">
        <label>Source Book</label>
        <div class="form-fields">
          <multi-select class="ddb-filter-source">
            {{#each sourceBooks}}
            <option value="{{this.value}}">{{this.label}}</option>
            {{/each}}
          </multi-select>
        </div>
      </div>
    </div>
    <div class="ddb-monster-filter-selects">
      <div class="form-group">
        <label>Creature Type</label>
        <div class="form-fields">
          <multi-select class="ddb-filter-type">
            {{#each creatureTypes}}
            <option value="{{this.value}}">{{this.label}}</option>
            {{/each}}
          </multi-select>
        </div>
      </div>
    </div>
    <div class="form-group">
      <label>Name</label>
      <div class="form-fields">
        <input type="text" class="ddb-filter-name" placeholder="Filter by name..."/>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Monsters (<span class="ddb-monster-visible-count">{{monsterCount}}</span> / {{monsterCount}})</legend>
    <div class="ddb-monster-checklist">
      {{#each monsters}}
      <div class="ddb-monster-entry" data-source="{{this.source}}" data-type="{{this.type}}" data-name="{{this.nameLower}}">
        <label>
          <input type="checkbox" name="actor-ids" value="{{this.id}}"/>
          {{this.label}}
        </label>
      </div>
      {{/each}}
    </div>
  </fieldset>
</section>
